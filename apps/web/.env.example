# Web-first /account + login (dev) — copy to .env.local and do not commit secrets
# -----------------------------------------------------------------------------

# 1) Session gate: leave unset to browse /account without sign-in (green banner in UI)
#    Set to 1 to require a signed session cookie to view /account
# ZS_WEB_AUTH=1

# 2) HMAC for zs_session cookie (32+ random chars). Required when ZS_WEB_AUTH=1
# ZS_SESSION_SECRET=change-me-32-chars-minimum-please-random

# 3) Shared one-line login token for POST /api/auth/dev-session (16+ chars). Not for production
# ZS_WEB_LOGIN_TOKEN=dev-only-unshared-long-token

# Optional: `zs_experience` httpOnly cookie is set from POST /api/account/experience (same HMAC key); cleared on
# /api/auth/logout. No separate env — uses ZS_SESSION_SECRET.

# Production: use OAuth2/OIDC (Auth0, Azure AD, etc.) and delete the dev session route.
NODE_ENV=development
