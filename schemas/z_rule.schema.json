{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "z_rule.schema.json",
  "title": "Z-Rule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "rule_name",
    "trigger",
    "context_requirements",
    "risk_class",
    "consent",
    "action_set",
    "governance",
    "audit_seal",
    "lifecycle"
  ],
  "properties": {
    "rule_id": { "type": "string", "minLength": 3, "maxLength": 128 },
    "rule_name": { "type": "string", "minLength": 3, "maxLength": 256 },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source", "event_type"],
      "properties": {
        "type": { "type": "string", "enum": ["event", "time", "threshold", "manual"] },
        "source": { "type": "string", "minLength": 1, "maxLength": 128 },
        "event_type": { "type": "string", "minLength": 1, "maxLength": 128 },
        "payload_schema_ref": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "context_requirements": {
      "description": "Declares which snapshot sections must be present to evaluate this rule.",
      "type": "object",
      "additionalProperties": false,
      "required": ["z_state", "lpbs_state", "ggaesp_360", "wellbeing_state", "session_meta"],
      "properties": {
        "z_state": { "type": "boolean" },
        "lpbs_state": { "type": "boolean" },
        "ggaesp_360": { "type": "boolean" },
        "wellbeing_state": { "type": "boolean" },
        "session_meta": { "type": "boolean" }
      }
    },
    "conditions": {
      "description": "A simple, deterministic condition language placeholder. Start simple; expand later.",
      "type": "array",
      "items": { "$ref": "z_condition.schema.json" },
      "default": []
    },
    "risk_class": { "type": "string", "enum": ["low", "medium", "high", "sacred"] },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "timeout_policy"],
      "properties": {
        "level": { "type": "string", "enum": ["auto", "notify", "require_human"] },
        "timeout_policy": { "type": "string", "enum": ["wait", "cancel", "escalate"] },
        "timeout_seconds": { "type": "integer", "minimum": 0, "maximum": 604800, "default": 0 }
      }
    },
    "action_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_actions", "max_repetitions", "cooldown_seconds", "rollback_allowed"],
      "properties": {
        "allowed_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "z_action.schema.json" }
        },
        "max_repetitions": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "cooldown_seconds": { "type": "integer", "minimum": 0, "maximum": 604800 },
        "rollback_allowed": { "type": "boolean" }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ai_allowed", "ai_forbidden", "human_override"],
      "properties": {
        "ai_allowed": {
          "type": "array",
          "items": { "type": "string", "enum": ["observe", "suggest", "simulate", "explain"] },
          "minItems": 1
        },
        "ai_forbidden": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["execute", "authorize", "modify_rules", "bypass_consent"]
          },
          "minItems": 1
        },
        "human_override": { "type": "string", "const": "always_true" }
      }
    },
    "audit_seal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ethical_intent", "creator_signature", "creation_time", "version"],
      "properties": {
        "ethical_intent": { "type": "string", "minLength": 3, "maxLength": 2000 },
        "creator_signature": { "type": "string", "minLength": 1, "maxLength": 256 },
        "creation_time": { "type": "string", "format": "date-time" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "activation_date", "review_interval_days"],
      "properties": {
        "status": { "type": "string", "enum": ["draft", "active", "paused", "retired"] },
        "activation_date": { "type": "string", "format": "date-time" },
        "review_interval_days": { "type": "integer", "minimum": 1, "maximum": 3650 }
      }
    }
  }
}
