{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "z_dashboard_config.schema.json",
  "title": "Z-Flow Dashboard Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["panels"],
  "properties": {
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "type"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["live_spine", "rule_registry", "consent_center", "stability"]
          }
        }
      }
    }
  }
}
