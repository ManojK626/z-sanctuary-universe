      "approval_gate": "BLUE",
      "approver": "AMK_GOKU_MULTI_APPROVAL",
      "auto_allowed": false
    },
    {
      "rung": 4,
      "level": "L4_Multi_Agent",
      "action": "Multiple agents coordinate (future)",
      "approval_gate": "BLUE",
      "approver": "AMK_ORCHESTRATION",
      "auto_allowed": false
    }
  ],
