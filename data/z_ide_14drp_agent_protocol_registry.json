  "session_validation_rules": [
    {
      "rule_id": "repo_root_check",
      "description": "Session repo_root must equal canonical Z-Sanctuary root",
      "blocking": true,
      "signal_on_fail": "RED"
    },
    {
      "rule_id": "latest_reports_check",
      "description": "Session must declare reports read before work",
      "blocking": false,
      "signal_on_fail": "YELLOW"
    },
    {
      "rule_id": "workspace_boundary_check",
      "description": "Session workspace must be in allowed_workspaces for agent",
      "blocking": true,
      "signal_on_fail": "RED"
    },
    {
      "rule_id": "high_risk_file_handoff_check",
      "description": "If session edits high-risk file, handoff must exist",
      "blocking": true,
      "signal_on_fail": "BLUE"
    },
    {
      "rule_id": "sacred_move_approval_check",
      "description": "If session attempts sacred move, AMK approval must be present",
      "blocking": true,
      "signal_on_fail": "RED"
    },
    {
      "rule_id": "forbidden_action_check",
      "description": "Session must not declare forbidden action",
      "blocking": true,
      "signal_on_fail": "RED"
    },
    {
      "rule_id": "file_collision_check",
      "description": "Two active sessions cannot edit same high-risk file",
      "blocking": true,
      "signal_on_fail": "RED"
    }
  ],
  "locked_law": [
