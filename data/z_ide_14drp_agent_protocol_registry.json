    "GREEN_not_equal_deploy",
    "AMK_GOKU_owns_sacred_moves",
    "No_shadow_work_no_off_record_changes",
    "Agent_signal_GREEN_means_safe_coordination",
    "Agent_signal_BLUE_means_AMK_decision",
    "Agent_signal_RED_means_block_immediately"
  ],
  "related_docs": [
