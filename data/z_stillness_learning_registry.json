{
  "schema": "z.stillness.learning.registry.v1",
  "registry_name": "Z-Stillness AI Learning Pathway",
  "mode": "read_only_alignment_learning",
  "phase": "Z-STILLNESS-LEARN-1",
  "stillness_law": {
    "idle_ai_must_not_invent_work": true,
    "idle_ai_may_review_docs": true,
    "idle_ai_may_generate_alignment_summary": true,
    "idle_ai_may_report_missing_links": true,
    "idle_ai_must_not_execute": true,
    "idle_ai_must_not_self_upgrade": true
  },
  "runtime_safety_flags": {
    "background_learning_daemon": false,
    "scheduled_stillness_cron": false,
    "autonomous_agent_pool": false,
    "provider_finetuning": false,
    "self_modifying_repository": false
  },
  "ecosystem_biology": {
    "root_system": {
      "metaphor": "Root system",
      "maps_to_hub": ["PC/NAS folders", "canonical registries", "source-of-truth docs"]
    },
    "mango_tree": {
      "metaphor": "Mango tree",
      "maps_to_hub": ["growth path nourishment", "mature receipts", "published fruit (human-gated)"]
    },
    "tarzan_tree": {
      "metaphor": "Tarzan tree navigation",
      "maps_to_hub": ["cross-branch navigation", "routing between capsules", "MOD-DIST / AMK SYNC maps"]
    },
    "pyramid": {
      "metaphor": "Pyramid of law",
      "maps_to_hub": ["Hierarchy Chief", "gates", "phase receipts vs charter"]
    },
    "quadruple_spine": {
      "metaphor": "Quadruple spine",
      "maps_to_hub": ["Cognitive / Data / Build / Oversight spines — doctrine only in Phase 1"]
    },
    "xbus_border": {
      "metaphor": "Membrane border",
      "maps_to_hub": ["Z-XBUS external connector gate"]
    },
    "mage_formula_layer": {
      "metaphor": "MAGE formula sheath",
      "maps_to_hub": ["Z-Ultra MAGE codex vocabulary"]
    },
    "replica_fabric": {
      "metaphor": "Bounded replication scaffold",
      "maps_to_hub": ["Replica Fabric reviewer posture — task-scoped only"]
    },
    "amk_dashboard": {
      "metaphor": "Conscious cockpit",
      "maps_to_hub": ["AMK indicators read-only overlays"]
    }
  },
  "learning_levels": [
    "identity",
    "ecosystem_map",
    "laws",
    "routing",
    "formula_awareness",
    "stillness_output"
  ],
  "allowed_outputs": [
    "learning_summary",
    "alignment_note",
    "missing_doc_suggestion",
    "role_clarity_suggestion",
    "risk_observation",
    "decision_packet_draft"
  ],
  "forbidden_outputs": [
    "runtime_action",
    "code_edit_without_task",
    "deploy",
    "provider_call",
    "secret_write",
    "live_connector",
    "self_replication",
    "model_training",
    "auto_merge",
    "auto_launch"
  ],
  "signal_classification_rules": {
    "GREEN": "read-only summaries, doctrinal recap, passive registry skim — operator-initiated idle learning",
    "YELLOW": "role overlap or taxonomy gap suggesting clearer docs routing",
    "BLUE": "ethics/policy question about persistent autonomy or tooling upgrade — AMK decides",
    "RED": "autonomous daemon, cron stillness bot, silent self-upgrade, deploy, provider hooks, billing, NAS sync agents"
  },
