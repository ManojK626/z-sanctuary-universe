  "signal_rules": {
    "RED": "Something broken, unsafe, missing, or required gate failed. RED blocks movement; no new feature lane until root cause understood.",
    "BLUE": "Technically tolerable but AMK/human decision required (deploy, billing, secrets, public, children/privacy, providers, bridges, Cloudflare, legal).",
    "YELLOW": "Caution, optional gap, advisory drift — monitor; quiet unless repeated or tied to a required gate.",
    "GREEN": "Safe internal baseline for next normal evidence lane — does not deploy.",
    "GOLD": "Sealed baseline / rest state — hold, archive, breathe.",
    "UNKNOWN": "Report missing or unread — not treated as RED unless a required gate file is missing (then YELLOW advisory)."
  },
  "decision_templates": {
    "red_block": ["RED Summary", "Root cause hint", "Affected systems", "Immediate no-go", "Smallest fix", "Commands to verify", "Rollback note", "AMK decision needed? yes/no"],
    "blue_brief": ["BLUE Decision Brief", "Decision required", "Options", "Risk of yes", "Risk of no", "Recommended safest option", "Human sign-off line"],
    "yellow_note": ["YELLOW Observation", "Monitor or clean later", "Suggested small cleanup"],
    "green_receipt": ["GREEN Receipt", "What passed", "What remains closed", "Next optional lane"]
  },
  "alert_policy": {
    "default_notification_classes": ["RED", "BLUE"],
    "yellow_escalation": "Repeat across 3+ daily strips or attachment to a required gate",
    "green_gold_notify": false
  },
  "forbidden_actions": [
    "live_ai_provider_call",
    "deploy",
    "billing_change",
    "bridge_exec",
    "auto_merge",
    "secrets_read_or_write",
    "nas_mount",
    "server_auto_start",
    "auto_fix_without_human"
  ],
