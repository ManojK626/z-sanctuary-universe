  "signal_rules": {
    "GREEN": "IDE sessions aligned; continue normal work with handoff discipline.",
    "YELLOW": "Advisory gap such as missing handoff or stale optional report.",
    "BLUE": "AMK decision required before movement.",
    "RED": "Wrong root, forbidden action, or unsafe high-risk edit conflict.",
    "GOLD": "Sealed baseline; hold posture.",
    "PURPLE": "Future-gated automation; do not run."
  },
  "red_stop_conditions": [
    "wrong repo root",
    ".cursor/projects used as build root",
    "package.json action in archive/cache path",
    "two IDEs editing same high-risk file without handoff",
    "deploy/secret/billing/provider/bridge action attempted",
    "no rollback note in handoff",
    "public/children/privacy lane opened without AMK"
  ],
  "blue_amk_decision_conditions": [
    "deploy decision",
    "cloudflare decision",
    "secrets or API keys",
    "provider calls",
    "auto-launch approval",
    "billing/pricing",
    "public release",
    "children/user-data/voice/camera/GPS"
  ],
  "forbidden_actions": [
    "runtime_ide_remote_control",
    "backend_bridge_execution",
    "deployment",
    "billing_mutation",
    "secret_write",
    "provider_calls",
    "auto_merge",
    "auto_launch"
  ],
