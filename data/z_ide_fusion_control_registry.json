  "supported_ides": ["cursor_ide", "vscode_copilot", "vscode_manual", "future_external_agent"],
  "session_rules": [
    "confirm real repo root before action",
    "read latest reports before work",
    "write handoff after work",
    "do not use .cursor/projects as build root",
    "do not create package.json in archive/cache folders",
    "do not edit same high-risk files from two IDEs without handoff",
    "no deploy/secrets/billing/provider/bridge/auto-launch"
  ],
  "handoff_rules": {
    "required_fields": [
      "timestamp",
      "session_id",
      "ide",
      "summary",
      "files_touched",
      "commands_run",
      "signal_result",
      "rollback_note",
      "next_recommended_lane"
    ],
    "journal_path": "data/ide-fusion/handoff_journal.jsonl",
    "stale_handoff_hours": 24
  },
