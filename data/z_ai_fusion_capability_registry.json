  "overlap_signal_rules": {
    "GREEN": "distinct or sibling roles bounded — lead/support spelled out in registry",
    "YELLOW": "metadata gaps or moderate purpose/output overlap — tighten docs before new teams",
    "BLUE": "likely duplicate headline or conflicting consolidation posture — AMK decides alias/merge-doc/reference-only",
    "RED": "unsafe fused lane: deploy/secrets/provider/billing/child-data/live connector/auto-merge without charter"
  },
  "overlap_score_bands_doc": [
    "0.00–0.30 distinct (GREEN-ish pair)",
    "0.31–0.60 related (YELLOW-ish pair)",
    "0.61–0.80 near-overlap (YELLOW/BLEED to BLUE)",
    "0.81–1.00 likely duplicate headline (BLUE AMK review)",
    "flags.unsafe_overlap forces RED regardless of numeric score"
  ],
